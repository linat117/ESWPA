# Protect Include Directory
# Deny direct access to PHP files except those listed below
# Last Updated: December 23, 2025

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
    <Files "member-forgot-password.php">
        Require all granted
    </Files>
    <Files "member-reset-password.php">
        Require all granted
    </Files>
    <Files "generate-id-card-pdf.php">
        Require all granted
    </Files>
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
    <Files "member-forgot-password.php">
        Allow from all
    </Files>
    <Files "member-reset-password.php">
        Allow from all
    </Files>
    <Files "generate-id-card-pdf.php">
        Allow from all
    </Files>
</IfModule>

